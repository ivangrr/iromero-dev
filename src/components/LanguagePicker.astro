---
const languages = [
  { code: 'en', label: 'English', flag: '🇺🇸' },
  { code: 'fr', label: 'Français', flag: '🇫🇷' },
  { code: 'es', label: 'Español', flag: '🇪🇸' },
];
const currentLang = Astro.currentLocale || 'en'; 
---

<div class="relative inline-block text-left">
  <div class="group relative flex items-center">
    <svg class="absolute left-3 h-4 w-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
    </svg>

    <select 
      id="lang-select"
      class="appearance-none bg-gray-800/50 border border-gray-700 text-white text-sm rounded-lg focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-10 pr-8 py-2 cursor-pointer hover:bg-gray-700 transition-colors"
      onchange="location = this.value;"
    >
      {languages.map((lang) => (
        <option value={lang.code === 'en' ? '/' : `/${lang.code}/`} selected={lang.code === currentLang}>
          {lang.flag} {lang.label}
        </option>
      ))}
    </select>
    
    <div class="absolute right-3 pointer-events-none text-gray-400">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</div>